package hua223.calamity.util.injector;

import org.objectweb.asm.tree.ClassNode;
import org.objectweb.asm.tree.FieldNode;

import java.io.IOException;
import java.util.List;

public class FieldWrapper extends CalamityWrapper {
    public String fieldDescriptor;
    public boolean isArr;

    public FieldWrapper(String injectionLine) throws IOException {
        super(injectionLine);
    }

    @Override
    protected void parser(String[] info, byte startIndex) {
        name = "calamity$" + info[startIndex];

        String field = info[++startIndex];

        switch (field) {
            case "I", "B", "D", "F", "C", "J", "S", "Z" -> fieldDescriptor = field;

            default -> {
                if (field.endsWith("[]")) {
                    field = field.substring(0, field.length() - 2);
                    fieldDescriptor = "[L" + field.replaceAll("\\.", "/") + ";";
                    isArr = true;
                } else {
                    fieldDescriptor = "L" + field.replaceAll("\\.", "/") + ";";
                }
            }
        }
    }

    @Override
    public void transformer(ClassNode classNode) {
        List<FieldNode> fieldNodes = classNode.fields;
        if (fieldNodes.stream().noneMatch(node -> node.name.equals(name) && node.desc.equals(fieldDescriptor))) {
            FieldNode node = new FieldNode(access, name,
                fieldDescriptor, null, null);
            classNode.fields.add(node);
            CalamityInjector.LOGGER.info("Injection field:{}", name);
            CalamityInjector.LOGGER.info("Field injection completed, target class:{}", targetClass);
        }
    }
}


public class MappingsConfuse {
    public static void main(String[] args) throws IOException {
        new MappingsConfuse().replaceAnnotation(args[0], args[2], args[3].isEmpty());
        //new MappingsConfuse().spawnConfuseMappings(args[0], args[1], args[2], args[3].isEmpty());
    }

    private void replaceAnnotation(String mixin, String buildRoot, boolean remap) throws IOException {
        FileReader reader = new FileReader(mixin);
        BufferedReader buffer = new BufferedReader(reader);

        String jsonText = buffer.lines().collect(Collectors.joining("\n"));
        reader.close();
        buffer.close();

        JsonObject main = JsonParser.parseString(jsonText).getAsJsonObject();
        String root = GsonHelper.getAsString(main, "package") + ".";

        //final String mappingDesc = "L" + MappingOverride.class.getName().replaceAll("\\.", "/") + ";";
        final String replaceDesc = "L" + Replace.class.getName().replaceAll("\\.", "/") + ";";
        AnnotationNode uniqueNode = new AnnotationNode("L" + Unique.class.getName().replaceAll("\\.", "/") + ";");
        AnnotationNode overwrite = null;
        if (!remap) {
            overwrite = new AnnotationNode("L" + Overwrite.class.getName().replaceAll("\\.", "/") + ";");
            overwrite.values = List.of("remap", false);
        }
        JsonArray mixins = GsonHelper.getAsJsonArray(main, "mixins");
        mixins.addAll(GsonHelper.getAsJsonArray(main, "client"));

        List<String> paths = new ArrayList<>(mixins.size());
        for (JsonElement p : mixins) paths.add(root + p.getAsString());
        buildRoot += "\\";
        for (String path : paths) {
            Path mixinClass = Path.of(buildRoot + path.replaceAll("\\.", "\\\\") + ".class");
            ClassReader mixinReader = new ClassReader(Files.readAllBytes(mixinClass));
            ClassNode node = new ClassNode();
            mixinReader.accept(node, 0);

            boolean transformation = false;
            for (MethodNode mt : node.methods) {
                if (mt.visibleAnnotations == null) continue;
                if (mt.visibleAnnotations.removeIf(annotation -> annotation.desc.equals(replaceDesc))) {
                    mt.visibleAnnotations.add(remap ? uniqueNode : overwrite);
                    transformation = true;
                }
            }

            if (transformation) {
                ClassWriter writer = new ClassWriter(ClassWriter.COMPUTE_MAXS);
                node.accept(writer);
                Files.write(mixinClass, writer.toByteArray());
            }
        }
    }

